{
    "name": "ukg/ielts-mock-test",
    "type": "project",
    "description": "IELTS Mock Test by UKG",
    "require": {
        "php": "^8.0",
        "laravel/framework": "^9.0",
        "laravel/tinker": "^2.7"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^6.0",
        "phpunit/phpunit": "^9.5",
        "spatie/laravel-ignition": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": { "psr-4": { "Tests\\": "tests/" } },
    "scripts": {
        "post-autoload-dump": [ "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump", "@php artisan package:discover --ansi" ],
        "post-root-package-install": [ "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"" ],
        "post-create-project-cmd": [ "@php artisan key:generate --ansi" ]
    },
    "extra": { "laravel": { "dont-discover": [] } },
    "config": { "optimize-autoloader": true, "preferred-install": "dist", "sort-packages": true,
        "policy": {
            "advisories": {
                "block": false
            }
        } },
    "minimum-stability": "stable",
    "prefer-stable": true
}
